rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /zmrSync/cars {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /zmrSync/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
