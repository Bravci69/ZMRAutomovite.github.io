{
  "rules": {
    ".read": false,
    ".write": false,
    "zmrCars": {
      ".read": true,
      ".write": "auth != null && (auth.token.admin === true || auth.token.cms === true)",
      "$carId": {
        ".validate": "newData.isObject() && newData.child('id').isString() && newData.child('id').val() === $carId && newData.child('updatedAt').isNumber()"
      }
    }
  }
}
